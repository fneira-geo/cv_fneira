%% cv-ats.tex.j2 — ATS-Friendly One-Page CV
%% Optimized for Applicant Tracking Systems (ATS)
%%
%% Features:
%% - Single column layout (no paracol, no multicolumn)
%% - Plain text headers with full URLs visible (not hidden in links)
%% - Plain text separators (commas, pipes) — no LaTeX math mode symbols
%% - No adaptive header styling (no tcolorbox)
%% - Straightforward text extraction order
%%
%% To update content: edit data/*.yaml then run: make ats
%% Experience entries shown: incluir_exec: true  (same flag as exec version)

\documentclass[10pt, letterpaper]{article}
[% include '_preamble.tex.j2' %]

%% ── ATS-friendly overrides ──────────────────────────────────────────────────────
%% Compact margins, no fancyhdr, no adaptive styling
\newgeometry{top=1.1cm, bottom=1.1cm, left=1.4cm, right=1.4cm}
\pagestyle{empty}
\setlength{\emergencystretch}{3em}

%% Disable fancyhdr footer (inherited from preamble)
\renewcommand{\headrulewidth}{0pt}
\renewcommand{\footrulewidth}{0pt}
\fancyhf{}

%% Remove adaptive header styling to ensure ATS compatibility
\renewcommand{\adaptiveheaderBegin}{}
\renewcommand{\adaptiveheaderEnd}{}

%% Section headings with breathing room
\titleformat{\section}
  {\small\bfseries\color{accent}}{}{0em}{}[\color{accent}\titlerule]
\titlespacing{\section}{0pt}{6pt}{5pt}
%% Remove needspace wrapper — not needed on a single page
\renewcommand{\section}[1]{\needspace{0pt}\oldsection{#1}}

%% Lists with better spacing
\setlist[itemize]{nosep, leftmargin=1.2em, topsep=0pt, itemsep=2pt, parsep=0pt}

%% Compact cventry (no needspace, no nopagebreak, smaller fonts)
\renewcommand{\cventry}[4]{%
  \noindent\textbf{\small #1}\hfill\textcolor{muted}{\footnotesize #4}\\[-2pt]%
  \textit{\footnotesize\textcolor{muted}{#2}}\hfill\textcolor{muted}{\footnotesize #3}%
  \vspace{1pt}%
}

\begin{document}

%% ── Header (ATS-safe: plain text, no adaptive styling) ────────────────────────
\begin{center}
  {\large\bfseries [[ perfil.nombre ]]}\\[1pt]
  {\footnotesize\color{headerSubtext} [[ perfil.titulo | e ]]}\\[2pt]
  \scriptsize
  [[ perfil.email ]] \textbar{} [[ perfil.telefono ]] \textbar{} [[ perfil.ubicacion ]]
  [% if perfil.linkedin %] \textbar{} linkedin.com/in/[[ perfil.linkedin ]][% endif %]
  [% if perfil.github %] \textbar{} github.com/[[ perfil.github ]][% endif %]
\end{center}
{\color{accent}\rule{\textwidth}{0.4pt}}
\vspace{1pt}

%% ── Experiencia ─────────────────────────────────────────────────────────────────
\section{Experiencia}
[% for exp in exp_reciente %]
\cventry{[[ exp.cargo | e ]]}{[[ exp.institucion | e ]]}{[[ exp.ubicacion | e ]]}{[[ exp.inicio | date ]] -- [[ exp.fin | date ]]}
[% if exp.logros %]
\begin{itemize}
  \item {\footnotesize [[ exp.logros[0] | trim | e ]]}
\end{itemize}
[% endif %]
[% endfor %]
[% if exp_anterior %]
\vspace{2pt}
{\footnotesize\textcolor{muted}{\textbf{Anterior:}}\ %
[% for exp in exp_anterior %]%
\textcolor{muted}{[[ exp.cargo | e ]], [[ exp.institucion | e ]] ([[ exp.inicio | date ]]--[[ exp.fin | date ]])}[% if not loop.last %]; [% endif %]%
[% endfor %]}
[% endif %]

%% ── Educación ───────────────────────────────────────────────────────────────────
\section{Educación}
[% for edu in educacion %]
\noindent{\footnotesize\textbf{[[ edu.titulo | e ]]}[% if edu.subtitulo %] --- \textit{[[ edu.subtitulo | e ]]}[% endif %]\hfill\textcolor{muted}{[[ edu.periodo ]]}}\\[-2pt]
{\scriptsize\textcolor{muted}{[[ edu.institucion | e ]]}}
\vspace{2pt}

[% endfor %]

%% ── Competencias (inline, text separators only) ──────────────────────────────────
\section{Competencias}
[% for grupo in competencias %]
{\footnotesize\textbf{[[ grupo.grupo | e ]]:} \textcolor{muted}{[[ grupo.habilidades | join(', ') | e ]]}}\\[1pt]
[% endfor %]

%% ── Idiomas ─────────────────────────────────────────────────────────────────────
\section{Idiomas}
{\footnotesize [% for lang in idiomas %]\textbf{[[ lang.idioma ]]:} [[ lang.nivel ]][% if not loop.last %] \textbar{} [% endif %][% endfor %]}

%% ── Footer with generation date (for tracking) ────────────────────────────────
\vfill
\noindent{\color{muted}\rule{\textwidth}{0.3pt}}\\[1pt]
\noindent\scriptsize\textcolor{muted}{[[ perfil.nombre ]]}\hfill\textcolor{muted}{[[ fecha_generacion ]]}

\end{document}
