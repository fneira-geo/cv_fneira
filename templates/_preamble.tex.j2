%% Shared preamble — included by all templates (full, exec, onepage)
%% Layout, margins, spacing: edit here.
%% Cosmetic style (font, colors, section headings): edit templates/styles/<name>.j2
%% To use a style: python3 build.py --style deedy   (or jake, simple, default)
%% NEVER edit output/*.pdf or the generated .tex files.

%% ── Encoding & Language ──────────────────────────────────────────────────────
\usepackage[T1]{fontenc}
\usepackage[utf8]{inputenc}
\usepackage[spanish, es-noshorthands]{babel}

%% ── Base Typography ───────────────────────────────────────────────────────────
\usepackage{microtype}
\setlength{\emergencystretch}{2em}   %% last-resort stretch to avoid overflows

%% ── Page Break Control ───────────────────────────────────────────────────────
\usepackage{needspace}

%% ── Page Layout ──────────────────────────────────────────────────────────────
\usepackage[letterpaper, top=1.8cm, bottom=1.5cm, left=2cm, right=2cm]{geometry}
\usepackage{fancyhdr}
\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0pt}
\renewcommand{\footrulewidth}{0.3pt}
\fancyfoot[L]{\footnotesize\textcolor{muted}{[[ perfil.nombre ]]}}
\fancyfoot[C]{\footnotesize\textcolor{muted}{\thepage}}
\fancyfoot[R]{\footnotesize\textcolor{muted}{[[ fecha_generacion ]]}}
\setlength{\parindent}{0pt}
\setlength{\parskip}{0pt}

%% ── Colors & Section Heading Packages ───────────────────────────────────────
%% Loaded here so all style files can use \definecolor and \titleformat.
\usepackage{xcolor}
\usepackage{titlesec}

%% ── Hooks for style-specific formatting ──────────────────────────────────────
%% Default: no-op. Redefined by adaptive.j2 to add gray background to header.
\newcommand{\adaptiveheaderBegin}{}
\newcommand{\adaptiveheaderEnd}{}

%% ── Style ────────────────────────────────────────────────────────────────────
%% Defines: font, accent/muted colors, \titleformat, \cventry
%% Default style: templates/styles/default.j2  (dark navy, lmodern)
[% include 'styles/' + (style | default('default')) + '.j2' %]

%% ── Needspace wrappers ───────────────────────────────────────────────────────
%% Must come AFTER \titleformat (defined in style above).
%% needspace: if fewer than N lines remain on the page, start a new page.
\let\oldsection\section
\renewcommand{\section}[1]{\needspace{8\baselineskip}\oldsection{#1}}
\let\oldsubsection\subsection
\renewcommand{\subsection}[1]{\needspace{5\baselineskip}\oldsubsection{#1}}

%% ── Lists ────────────────────────────────────────────────────────────────────
\usepackage{enumitem}
\setlist[itemize]{nosep, leftmargin=1.5em, topsep=4pt, itemsep=4pt}

%% ── Links ────────────────────────────────────────────────────────────────────
%% Uses accent color defined in the style above.
\usepackage[hidelinks]{hyperref}
\hypersetup{colorlinks=true, urlcolor=accent, linkcolor=black}
